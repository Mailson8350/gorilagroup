# Supabase (obrigatório) — Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

SUPABASE_STORAGE_BUCKET=gorila-uploads

# Auth admin (JWT das rotas /api/admin/*)
JWT_SECRET=YOUR_JWT_SECRET

# Password inicial do admin (apenas para npm run seed)
ADMIN_PASSWORD=admin123

# Local dev (opcional)
PORT=3000